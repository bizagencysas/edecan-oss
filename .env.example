# Edecán public configuration template
#
# Copy this file to `.env`, generate the two secrets below, and keep the
# resulting file private. Empty provider credentials disable that provider;
# the default stub providers keep local development deterministic and free.
# Full reference: docs/configuracion.md

# Runtime
ENV=dev
PUBLIC_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
LOG_LEVEL=INFO
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Required secrets. Production refuses to start with these public values.
# JWT_SECRET: python -c "import secrets; print(secrets.token_urlsafe(32))"
# LOCAL_MASTER_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_SECRET=TU_JWT_SECRET_AQUI
LOCAL_MASTER_KEY=TU_LOCAL_MASTER_KEY_FERNET_AQUI
KMS_KEY_ID=

# PostgreSQL / Redis
DATABASE_URL=postgresql+asyncpg://edecan:edecan@localhost:5432/edecan
REDIS_URL=redis://localhost:6379/0

# S3 / SQS. These values target the LocalStack service from `make deps`.
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=edecan-files
SQS_QUEUE_URL=http://localhost:4566/000000000000/edecan-jobs
# Hard cap per uploaded file (25 MiB by default), independent of plan quota.
MAX_UPLOAD_BYTES=26214400

# Platform LLM fallbacks. Tenant chat credentials are connected in the UI
# and encrypted per tenant; these values are mainly for system-owned jobs.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PRINCIPAL=claude-sonnet-4-5
ANTHROPIC_MODEL_RAPIDO=claude-haiku-4-5
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=

# Embeddings and web research
EMBEDDINGS_MODEL=
EMBEDDINGS_DIM=1536
SEARCH_PROVIDER=stub
BRAVE_API_KEY=
TAVILY_API_KEY=

# Voice. `stub` is offline and safe for first boot.
VOICE_STT_PROVIDER=stub
VOICE_TTS_PROVIDER=stub
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
POLLY_VOICE=Lupe

# OAuth application credentials. End users connect their own accounts.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Optional hosted-instance services
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SES_FROM_EMAIL=
SENTRY_DSN=

# Browser, media and commerce defaults
BROWSER_FETCH_PROVIDER=httpx
BROWSER_USER_AGENT=EdecanBot/1.0
BROWSER_MAX_FETCH_BYTES=2000000
BROWSER_TIMEOUT_SECONDS=20
IMAGES_PROVIDER=stub
IMAGES_BASE_URL=
IMAGES_API_KEY=
IMAGES_MODEL=
QUOTES_PROVIDER=stub
# Only paper execution is currently supported; real-money execution is off.
COMMERCE_MODE=paper

# Agent and remote-control budgets
MISSIONS_MAX_STEPS=8
MISSIONS_STEP_TIMEOUT_SECONDS=300
MISSIONS_PARALLEL_MAX=3
REMOTE_FRAME_MIN_INTERVAL_SECONDS=1.0

# Desktop/local runtime. The packaged desktop app sets these automatically.
EDECAN_LOCAL_MODE=false
DATA_DIR=~/.edecan/data
SERVE_WEB_DIR=
LOCAL_API_PORT=8765
EDECAN_LOCAL_REPO_PATH=
# Core self-repair is source-only, local-only and disabled by default.
# Commands are exact JSON argv arrays; each invocation still needs approval.
EDECAN_SELF_REPAIR_ENABLED=false
EDECAN_SELF_REPAIR_TEST_COMMANDS_JSON=[]
EDECAN_SELF_REPAIR_INSTALL_COMMANDS_JSON=[]
EDECAN_SELF_REPAIR_COMMAND_TIMEOUT_SECONDS=300
QUEUE_PROVIDER=sqs
OLLAMA_BASE_URL=http://localhost:11434
CLAUDE_CLI_PATH=
CODEX_CLI_PATH=
LLM_CLI_TIMEOUT_SECONDS=300
VERTEX_MODEL_PRINCIPAL=gemini-2.5-pro
VERTEX_MODEL_RAPIDO=gemini-2.5-flash
SKILLS_INDEX_URL=https://skills.sh
HOMEASSISTANT_TIMEOUT_SECONDS=15

# Optional commercial telephony plugin; disabled by default.
TWILIO_MEDIA_STREAMS_ENABLED=false
