<?xml version="1.0" encoding="utf-8"?>
<!--
    Solo los permisos que la app realmente usa (ROADMAP_V2.md §6.1):
    `INTERNET` para hablar con `/v1/*`, `RECORD_AUDIO` para el push-to-talk
    de la pestaña Voz (WP-V4-04, `POST /v1/voice/transcribe`) — pedido en
    tiempo de ejecución desde `VozScreen`, este `<uses-permission>` solo lo
    declara. Nada de contactos/ubicación/cámara/notificaciones todavía.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.Edecan"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:supportsRtl="true">
        <!--
            android:usesCleartextTraffic="false" es el default explícito
            (producción, HTTPS-only). networkSecurityConfig apunta a
            @xml/network_security_config, que existe en DOS versiones —
            `src/main/res/xml/` (cleartext prohibido, la que usa `release`)
            y `src/debug/res/xml/` (cleartext PERMITIDO, la que Android
            resuelve automáticamente para builds `debug` por las reglas
            normales de merge de resources — mismo nombre, el source set
            más específico gana). Así un desarrollador puede apuntar la app
            a `http://localhost:8000` o a un servidor en su LAN sin HTTPS
            SOLO en debug, sin abrirle esa puerta a un release firmado que
            un cliente instale de verdad. Ver docs/movil-android.md.
        -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Edecan"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
