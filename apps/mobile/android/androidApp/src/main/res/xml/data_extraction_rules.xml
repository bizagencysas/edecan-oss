<?xml version="1.0" encoding="utf-8"?>
<!-- El pairing, los tokens y el perfil local pertenecen a esta instalación.
     No viajan a copias en la nube ni a otro teléfono durante una migración. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
