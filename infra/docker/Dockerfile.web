# syntax=docker/dockerfile:1
# ============================================================================
# Edecán — apps/web (Next.js / App Router). Imagen de producción para
# self-hosting.
#
# Requiere que apps/web/package-lock.json esté commiteado (usamos `npm ci`,
# reproducible; apps/web queda fuera del workspace uv,
# es un proyecto Next.js/TypeScript independiente con su propio package.json).
#
# IMPORTANTE: construir con el contexto en apps/web (NO en la raíz del repo):
#
#   docker build -f infra/docker/Dockerfile.web -t edecan-web:dev apps/web
#
# ============================================================================

# --- deps: dependencias completas (dev incluido, hacen falta para el build) --
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

# --- builder: next build -------------------------------------------------------
FROM node:22-alpine AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=deps /app/node_modules ./node_modules
# Copia explícita: evita que `.env.local` u otros secretos del contexto entren
# en las capas de build. `public/` es opcional en este repositorio.
COPY package.json .eslintrc.json next-env.d.ts next.config.mjs security-headers.mjs postcss.config.mjs tailwind.config.ts tsconfig.json ./
COPY src ./src
# NEXT_PUBLIC_API_URL se hornea en el bundle del cliente en build time.
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
RUN mkdir -p public && npm run build

# --- prod-deps: SOLO dependencias de producción para la imagen final --------
FROM node:22-alpine AS prod-deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# --- runtime: next start, usuario no root -------------------------------------
FROM node:22-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000

# The official Node Alpine image already provides the non-root `node` user
# (UID/GID 1000). Reuse it instead of attempting to recreate a conflicting ID.
COPY --from=prod-deps --chown=node:node /app/node_modules ./node_modules
COPY --from=builder   --chown=node:node /app/public       ./public
COPY --from=builder   --chown=node:node /app/.next        ./.next
COPY --from=builder   --chown=node:node /app/package.json ./package.json
COPY --from=builder   --chown=node:node /app/next.config.mjs ./next.config.mjs
COPY --from=builder   --chown=node:node /app/security-headers.mjs ./security-headers.mjs

USER node

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD ["node", "-e", "require('http').get('http://127.0.0.1:3000/', r => process.exit(r.statusCode < 500 ? 0 : 1)).on('error', () => process.exit(1))"]

CMD ["npm", "start"]
